#!/usr/bin/env bash
# memos — Memos RTC TEK-KOMUT kontrol arayüzü.
#
# Dağınık script'leri (launch.sh / run_rtc.sh / tui_daemon.sh / watchdog.sh / engine.sh /
# reset_state.sh) tek ezberlenir komutun altında toplar — hepsine DELEGE eder (mantık kopyalanmaz).
# Tüm yollar scripts/.launch.conf'u TEK KAYNAK env olarak kullanır (lib_launchconf.sh).
#
#   ./memos config            # başlatma parametrelerini düzenle (interaktif menü → .launch.conf)
#   ./memos start             # ÖN PLANDA TUI (bu terminalde; .launch.conf env'iyle)
#   ./memos up                # 7/24 ARKA PLAN: tmux TUI + watchdog (ölü/hung'da auto-restart)
#   ./memos down              # watchdog + motoru durdur
#   ./memos restart           # down + up
#   ./memos status            # motor + watchdog + son heartbeat
#   ./memos attach            # tmux panellerini canlı izle (bırak: Ctrl-b d)
#   ./memos logs              # canlı log akışı (trades + heartbeat)
#   ./memos reset [args...]   # state/log/history reset (reset_state.sh'e geçer; örn: --all -y)
#   ./memos dashboard         # mobil izleme paneli (telefon tarayıcı; salt-okuma) · stop ile durdur
#   ./memos bot               # Telegram salt-okuma sorgu botu (/status /pos /pnl /trades) · stop ile durdur
#   ./memos boot-install      # boot'ta otomatik başlat (systemd --user, TUI/tmux + linger)
#   ./memos boot-uninstall    # boot otomatiğini kaldır
#   ./memos build             # sadece release TUI binary'i derle
set -u
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$REPO_DIR" || exit 1

SESSION="${MEMOS_TUI_SESSION:-memos}"
SERVICE="memos-watchdog"
UNIT_DST="$HOME/.config/systemd/user/${SERVICE}.service"
WD_PIDFILE="logs/.watchdog.pid"
DASH_SERVICE="memos-dashboard"
DASH_UNIT_DST="$HOME/.config/systemd/user/${DASH_SERVICE}.service"
DASH_PIDFILE="logs/.dashboard.pid"
DASH_PORT="${MEMOS_DASH_PORT:-8090}"
BOT_SERVICE="memos-bot"
BOT_UNIT_DST="$HOME/.config/systemd/user/${BOT_SERVICE}.service"
BOT_PIDFILE="logs/.bot.pid"
HEARTBEAT="logs/heartbeat.jsonl"
mkdir -p logs

have_systemd_unit() { [ -f "$UNIT_DST" ]; }
systemd_active()   { systemctl --user is-active --quiet "$SERVICE" 2>/dev/null; }
wd_nohup_alive()   { [ -f "$WD_PIDFILE" ] && kill -0 "$(cat "$WD_PIDFILE" 2>/dev/null)" 2>/dev/null; }
have_dash_unit()   { [ -f "$DASH_UNIT_DST" ]; }
dash_systemd_active() { systemctl --user is-active --quiet "$DASH_SERVICE" 2>/dev/null; }
dash_alive() { dash_systemd_active || { [ -f "$DASH_PIDFILE" ] && kill -0 "$(cat "$DASH_PIDFILE" 2>/dev/null)" 2>/dev/null; }; }
have_bot_unit()    { [ -f "$BOT_UNIT_DST" ]; }
bot_systemd_active() { systemctl --user is-active --quiet "$BOT_SERVICE" 2>/dev/null; }
bot_configured() { . scripts/lib_launchconf.sh 2>/dev/null; load_launch_conf 2>/dev/null; [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -n "${TELEGRAM_CHAT_ID:-}" ]; }
bot_alive() { bot_systemd_active || { [ -f "$BOT_PIDFILE" ] && kill -0 "$(cat "$BOT_PIDFILE" 2>/dev/null)" 2>/dev/null; }; }

build_release() {
  echo "🔨 release TUI binary derleniyor (gerekirse)..."
  ./run_rtc.sh --tui --release --build-only
}

cmd_up() {
  build_release || { echo "❌ derleme başarısız → up iptal."; exit 1; }
  rm -f logs/.watchdog.pause 2>/dev/null   # bakım duraklatması varsa kaldır
  if have_systemd_unit; then
    systemctl --user start "$SERVICE"
    echo "✅ up (systemd): '$SERVICE' başlatıldı → watchdog motoru tmux '$SESSION' içinde tutuyor."
  else
    if wd_nohup_alive; then echo "ℹ️  watchdog zaten çalışıyor (PID $(cat "$WD_PIDFILE"))."; exit 0; fi
    WATCHDOG_TARGET=tui nohup ./scripts/watchdog.sh --release >>logs/watchdog.log 2>&1 &
    echo $! > "$WD_PIDFILE"
    echo "✅ up (nohup): watchdog (TARGET=tui, PID $(cat "$WD_PIDFILE")) → motoru tmux '$SESSION' içinde tutuyor."
    echo "   (kalıcı boot için: ./memos boot-install)"
  fi
  echo "── Panel ──"; dash_start || true   # mobil izleme paneli de kalksın
  echo "── Telegram bot ──"; bot_start || true   # salt-okuma sorgu botu
  echo "   izle: ./memos attach · durum: ./memos status · durdur: ./memos down"
}

cmd_down() {
  # ÖNCE watchdog'u TAM durdur (yoksa motoru geri başlatır), SONRA motoru kapat.
  if have_systemd_unit && systemd_active; then
    systemctl --user stop "$SERVICE"; echo "🛑 watchdog durduruldu (systemd)."
  fi
  if wd_nohup_alive; then
    local wp; wp="$(cat "$WD_PIDFILE" 2>/dev/null)"
    kill "$wp" 2>/dev/null
    # watchdog 'sleep 60' içinde olabilir → bash TERM trap'ini sleep bitene dek erteler. Child
    # sleep'i de kesince trap hemen çalışır (anında çıkış, tek-fazla-kontrol yarışı önlenir).
    pkill -TERM -P "$wp" 2>/dev/null || true
    for _ in 1 2 3; do kill -0 "$wp" 2>/dev/null || break; sleep 1; done
    kill -0 "$wp" 2>/dev/null && kill -9 "$wp" 2>/dev/null   # inatçıysa escalate
    echo "🛑 watchdog durduruldu (nohup)."
  fi
  rm -f "$WD_PIDFILE" 2>/dev/null
  ./scripts/tui_daemon.sh stop 2>/dev/null || true
  ./scripts/engine.sh stop 2>/dev/null || true   # olası headless artığı
  dash_stop
  bot_stop
  echo "✅ down: watchdog + motor + panel + bot durduruldu."
}

cmd_status() {
  echo "── Motor ──────────────────────────────"
  ./scripts/tui_daemon.sh status
  echo "── Watchdog ───────────────────────────"
  if have_systemd_unit; then
    printf "  systemd: "; systemctl --user is-active "$SERVICE" 2>/dev/null || true
    systemctl --user is-enabled "$SERVICE" 2>/dev/null | sed 's/^/  boot:    /'
  elif wd_nohup_alive; then
    echo "  nohup: çalışıyor (PID $(cat "$WD_PIDFILE"))"
  else
    echo "  çalışmıyor (./memos up ile başlat)"
  fi
  [ -f logs/.watchdog.pause ] && echo "  ⏸️  DURAKLATILMIŞ (logs/.watchdog.pause var → restart yok)"
  echo "── Panel ──────────────────────────────"
  if dash_alive; then echo "  çalışıyor (port $DASH_PORT)"; else echo "  kapalı (./memos dashboard ile başlat)"; fi
  echo "── Telegram bot ───────────────────────"
  if bot_alive; then echo "  çalışıyor (/status /pos /pnl /trades /report)"
  elif ! bot_configured; then echo "  yapılandırılmamış (.launch.conf TELEGRAM_* boş)"
  else echo "  kapalı (./memos bot ile başlat)"; fi
  return 0
}

cmd_logs() {
  echo "📜 canlı log (Ctrl-C ile çık) — trades + heartbeat:"
  tail -n 20 -f logs/robotic_trading.log 2>/dev/null
}

cmd_boot_install() {
  build_release || { echo "❌ derleme başarısız → kurulum iptal."; exit 1; }
  mkdir -p "$(dirname "$UNIT_DST")"
  cat > "$UNIT_DST" <<UNIT
# Memos Trading Engine Watchdog — systemd --user (KÖK GEREKTİRMEZ). ./memos boot-install üretir.
[Unit]
Description=Memos Trading Engine Watchdog (TUI/tmux)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$REPO_DIR
ExecStart=$REPO_DIR/scripts/watchdog.sh --release
Environment=WATCHDOG_TARGET=tui
Restart=always
RestartSec=10
# KillMode=process: systemd YALNIZ watchdog'u yönetir; tmux motorunu cgroup'la öldürmez.
KillMode=process

[Install]
WantedBy=default.target
UNIT
  # Mobil izleme paneli — ayrı systemd --user servisi (boot'ta motorla birlikte kalkar).
  dash_stop  # olası nohup paneli durdur (port çakışmasını önle)
  cat > "$DASH_UNIT_DST" <<UNIT
# Memos mobil izleme paneli — systemd --user (snapshot.json sunar; salt-okuma). ./memos boot-install üretir.
[Unit]
Description=Memos RTC Dashboard (mobil izleme)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$REPO_DIR
ExecStart=/usr/bin/env python3 $REPO_DIR/scripts/dashboard_server.py $DASH_PORT
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
UNIT
  # Telegram sorgu botu — token+chat varsa ayrı systemd servisi olarak kur.
  local bot_units="$SERVICE $DASH_SERVICE"
  if bot_configured; then
    bot_stop  # olası nohup botu durdur
    cat > "$BOT_UNIT_DST" <<UNIT
# Memos Telegram salt-okuma sorgu botu — systemd --user. ./memos boot-install üretir.
[Unit]
Description=Memos RTC Telegram Bot (salt-okuma sorgu)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$REPO_DIR
ExecStart=/usr/bin/env python3 $REPO_DIR/scripts/telegram_bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
UNIT
    bot_units="$bot_units $BOT_SERVICE"
  fi
  systemctl --user daemon-reload
  systemctl --user enable --now $bot_units
  loginctl enable-linger "$USER" 2>/dev/null || echo "  ⚠️ linger açılamadı (logout'ta durabilir): loginctl enable-linger $USER"
  echo "✅ boot-install: $bot_units kuruldu + etkin (boot'ta + logout'ta 7/24)."
  dash_print_urls
  echo "   durum: ./memos status · izle: ./memos attach · kaldır: ./memos boot-uninstall"
}

dash_print_urls() {
  local lan; lan="$(hostname -I 2>/dev/null | tr ' ' '\n' | grep -E '^(192|10|172)\.' | head -1)"
  [ -n "$lan" ] && echo "   LAN     : http://$lan:$DASH_PORT"
  local ts; ts="$(tailscale ip -4 2>/dev/null | head -1)"
  [ -n "$ts" ] && echo "   Tailscale: http://$ts:$DASH_PORT  (her yerden)" \
               || echo "   Tünel    : Tailscale yok → her-yerden için: curl -fsSL https://tailscale.com/install.sh | sh && sudo tailscale up"
}
dash_start() {  # systemd-farkında: unit kuruluysa systemctl, değilse nohup
  if dash_alive; then echo "ℹ️  panel zaten çalışıyor (port $DASH_PORT)."; dash_print_urls; return 0; fi
  if have_dash_unit; then systemctl --user start "$DASH_SERVICE"
  else
    nohup python3 scripts/dashboard_server.py "$DASH_PORT" >>logs/dashboard.log 2>&1 &
    echo $! > "$DASH_PIDFILE"
  fi
  sleep 1
  dash_alive && echo "✅ panel çalışıyor (salt-izleme, port $DASH_PORT):" || { echo "❌ panel başlamadı (logs/dashboard.log)."; return 1; }
  dash_print_urls
}
dash_stop() {
  if have_dash_unit && dash_systemd_active; then systemctl --user stop "$DASH_SERVICE"; echo "🛑 panel durduruldu (systemd)."; fi
  if [ -f "$DASH_PIDFILE" ] && kill -0 "$(cat "$DASH_PIDFILE" 2>/dev/null)" 2>/dev/null; then
    kill "$(cat "$DASH_PIDFILE")" 2>/dev/null; echo "🛑 panel durduruldu (nohup)."
  fi
  rm -f "$DASH_PIDFILE"
}
cmd_dashboard() {
  case "${1:-start}" in
    stop)     dash_stop ;;
    start|"") dash_start ;;
    *) echo "kullanım: ./memos dashboard {start|stop}" ;;
  esac
}

bot_start() {  # Telegram salt-okuma sorgu botu (token+chat yoksa atla). systemd-farkında.
  if ! bot_configured; then echo "ℹ️  Telegram bot: token/chat boş (.launch.conf) → atlandı."; return 0; fi
  if bot_alive; then echo "ℹ️  Telegram bot zaten çalışıyor."; return 0; fi
  if have_bot_unit; then systemctl --user start "$BOT_SERVICE"
  else
    nohup python3 scripts/telegram_bot.py >>logs/bot.log 2>&1 &
    echo $! > "$BOT_PIDFILE"
  fi
  sleep 1
  bot_alive && echo "✅ Telegram bot çalışıyor (/status /pos /pnl /trades /report /help)" \
            || echo "❌ bot başlamadı (logs/bot.log)."
}
bot_stop() {
  if have_bot_unit && bot_systemd_active; then systemctl --user stop "$BOT_SERVICE"; echo "🛑 Telegram bot durduruldu (systemd)."; fi
  if [ -f "$BOT_PIDFILE" ] && kill -0 "$(cat "$BOT_PIDFILE" 2>/dev/null)" 2>/dev/null; then
    kill "$(cat "$BOT_PIDFILE")" 2>/dev/null; echo "🛑 Telegram bot durduruldu (nohup)."
  fi
  rm -f "$BOT_PIDFILE"
}
cmd_bot() {
  case "${1:-start}" in
    stop)     bot_stop ;;
    start|"") bot_start ;;
    *) echo "kullanım: ./memos bot {start|stop}" ;;
  esac
}

cmd_boot_uninstall() {
  if have_systemd_unit || have_dash_unit || have_bot_unit; then
    systemctl --user disable --now "$SERVICE" "$DASH_SERVICE" "$BOT_SERVICE" 2>/dev/null || true
    rm -f "$UNIT_DST" "$DASH_UNIT_DST" "$BOT_UNIT_DST"; systemctl --user daemon-reload
    echo "✅ boot-uninstall: motor + panel + bot servisleri kaldırıldı (çalışıyorsa ./memos down ile durdur)."
  else
    echo "ℹ️  Kurulu systemd servisi yok."
  fi
}

usage() { sed -n '2,21p' "$0"; }

case "${1:-status}" in
  config)         exec ./scripts/launch.sh ;;
  start)          exec ./run_rtc.sh --tui --release ;;
  build)          build_release ;;
  up)             cmd_up ;;
  down)           cmd_down ;;
  restart)        cmd_down; sleep 1; cmd_up ;;
  status)         cmd_status ;;
  attach)         exec ./scripts/tui_daemon.sh attach ;;
  logs)           cmd_logs ;;
  reset)          shift; exec ./scripts/reset_state.sh "$@" ;;
  dashboard)      shift; cmd_dashboard "$@" ;;
  bot)            shift; cmd_bot "$@" ;;
  boot-install)   cmd_boot_install ;;
  boot-uninstall) cmd_boot_uninstall ;;
  -h|--help|help) usage ;;
  *) echo "Bilinmeyen komut: $1"; echo; usage; exit 1 ;;
esac
