			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Run RTC CLI (Release)",
			"type": "shell",
			"command": "./run_rtc.sh --release",
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
