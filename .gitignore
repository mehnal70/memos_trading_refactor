# Build artifacts
target/
**/target/

# Logs
logs/
*.log

# SQLite veritabanları (runtime'da üretilir, ~GB olabilir)
*.db
*.db-wal
*.db-shm

# Test çıktı artıkları (her run'da yeniden üretilir)
test_results.json
test_results_array.json

# Runtime data klasörleri (DB binary'leri ~GB ölçeğinde, snapshot, reports, cache)
data/
memos_trading_core/data/
reports/
memos_trading_core/reports/

# Backtest job runtime çıktıları (her run'da yeniden üretilir)
config/active_profile.json
config/best_params.json

# Runtime state (engine yazıyor, restart'ta yeniden üretilir).
# CONFIG olan rtc_config.json, robotic_profiles.json, trade_quality.json track'te kalır.
config/*_state.json
config/*_snapshot.json
config/*.bak_*
config/adaptive_params.json

# Editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# LibreOffice / OpenOffice geçici lock dosyaları
.~lock.*#

# Tar yedekler
*.tar.gz

# Geçici / yedek envanter dosyaları
liste.txt
src_rs_files.txt
Cargo_v1.toml

# Hassas: token / SSH anahtar / kişisel notlar
git_tokens.txt
ssh_key
ssh_key.pub
docs/*.odt
docs/yapılacaklar

# Defense-in-depth: env, anahtar, kimlik bilgileri
# Not: .env globu her seviyede yakalar (kök ve memos_trading_core/.env dahil).
.env
.env.*
# şablon dosyası izlenir (secret içermez):
!.env.example
memos_trading_core/.env
*.key
*.pem
credentials.json
secrets.json
