# ============================================================================
# memos_trading — örnek ortam değişkenleri (.env şablonu)
#
# Kullanım: `cp .env.example .env` ve değerleri doldur. rtc_headless / rtc_tui
# boot'ta dotenv ile yükler. Gösterilen değerler DEFAULT'lardır (env eksik/geçersizse
# bu değerler kullanılır) — yani çoğu satır opsiyoneldir, sadece davranışı değiştirmek
# için override edersin. Secret'lar boş bırakılmıştır.
# ============================================================================

# ── Çekirdek / mod ──────────────────────────────────────────────────────────
TRADE_SYMBOL=BTCUSDT
TRADE_MARKET=spot                 # spot | futures
TRADE_INTERVAL=1m                 # cycle + backtest + screener TF (rtc_headless)
DB_PATH=data/trader.db            # kanonik DB (tüm interface'ler aynı path)
TRADING_MODE=Paper                # Paper | Live | Backtest (güvenli default Paper)
# BINANCE_PAPER_MODE=false        # legacy: =false → Live (TRADING_MODE önceliklidir)

# ── Borsa API anahtarları (Live için gerekli) ───────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Market'e özel override (opsiyonel; yoksa yukarıdakiler kullanılır):
# BINANCE_SPOT_API_KEY=
# BINANCE_SPOT_API_SECRET=
# BINANCE_FUTURES_API_KEY=
# BINANCE_FUTURES_API_SECRET=

# ── Sermaye / canlı emniyet ─────────────────────────────────────────────────
STARTING_CAPITAL=10000            # başlangıç sermayesi ($). Değiştirmek DB'ye
                                  # dokunmadan cold-start tetikler (recovery guard)
LIVE_DRY_RUN=false                # true → Live'da emir göndermez, sadece loglar
LIVE_MAX_NOTIONAL_USD=100         # tek emir notional tavanı ($)
COMMISSION_RATE=0.001             # taker komisyon oranı (Binance USDⓈ-M ≈ 0.0004)

# ── Maker LIMIT girişi (opt-in) ─────────────────────────────────────────────
USE_LIMIT_ENTRY=false             # true → taker MARKET yerine POST_ONLY maker
LIMIT_ENTRY_TIMEOUT_MS=2000       # tek denemede fill bekleme
LIMIT_ENTRY_MAX_ATTEMPTS=3        # re-quote deneme sayısı
LIMIT_ENTRY_MAX_SPREAD_BPS=50     # spread guard (bps); 0 → kapalı
LIMIT_ENTRY_FALLBACK_MARKET=true  # maker dolmazsa taker'a düş (false → trade atla)
MAKER_COMMISSION_RATE=0.001       # maker dolum komisyonu (default = COMMISSION_RATE)

# ── Pozisyon boyutlama (RuntimeTuning) ──────────────────────────────────────
BASE_ALLOC_FRACTION=0.10          # base_alloc = equity × bu × risk_appetite
ALLOC_FLOOR_FRACTION=0.25         # Kelly ölçeği base_alloc × bu oranın altına inmez
KELLY_LOSS_STREAK_WINDOW=5        # son N kapanışta zarar sayımı (dinamik ölçek)
KELLY_STATS_WINDOW=50             # win_prob/avg_win/avg_loss için son N kapanış
FALLBACK_TP_PCT=3.0               # ParameterStore okunamazsa son-çare TP (%)
FALLBACK_SL_PCT=1.5               # ParameterStore okunamazsa son-çare SL (%)
REENTRY_COOLDOWN_SECS=0           # kapanıştan sonra N sn yeniden açma yok (churn
                                  # koruması); 0 → kapalı, önerilen ~60

# ── Rejim / strateji / risk akışı ───────────────────────────────────────────
REGIME_CONTEXT_TTL_SECS=900       # rejim cache TTL (0 → her cycle yeniden hesapla)
REGIME_GBT=true                   # GBT rejim yönünü beslesin mi (0/false → kapat)
GBT_EDGE_LEGACY=false             # true → eski per-tick GBT edge yolu
STRATEGY_SELECT_EVAL=false        # true → adayları mini-backtest skoruyla seç
LET_WINNERS_RUN=false             # true → sabit TP'yi uzağa it, çıkışı trailing yönetir
MIN_HOLDING_SECS_STRATEGY=30      # StrategySignal kapanışı min tutma süresi (SL/TP hariç)
MAX_ENTRY_PRICE_DEVIATION_PCT=5   # entry↔candle sapma tavanı (%); 0 → guard kapalı
CANDLE_FRESHNESS_SECS=300         # mum tazelik eşiği (sn)

# ── Veri / borsa kapsamı ────────────────────────────────────────────────────
STALE_FEED_MAX_AGE_SECS=3600       # en yeni mum bundan eskiyse YENİ açılış yok
                                   # (donuk feed phantom giriş koruması); 0 → kapalı.
                                   # Yüksek interval'da (4h/1d) yükselt.
# FORCE_LIVE_EXCHANGES=            # virgül ayraçlı; canlı feed'i olmayan borsayı zorla
# ALLOW_BIST=false                 # legacy: BIST'i cycle'a ekler
# MULTI_TF=                        # HTF (üst TF) veri akışını aç

# ── Log throttle (opsiyonel) ────────────────────────────────────────────────
# LOG_DATAINGEST_COOLDOWN_SECS=300
# RISK_BLOCK_LOG_COOLDOWN_SECS=60
