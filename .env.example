# ============================================================================
# memos_trading — .env şablonu (cp .env.example .env)
#
# .env = YALNIZ SIRLAR. Davranış (mod/strateji/sermaye/sizing) artık PROFİLLERDE:
#   ./memos profiles            # 8 profili listele (paper/live × general/xs/carry/blend)
#   ./memos use <numara|ad>     # profili aktif et (örn: ./memos use paper-blend / ./memos use 8)
#   ./memos up                  # aktif profille başlat
#
# Profil = scripts/.launch.conf'a yazılır (profiles/_base.conf + profiles/<ad>.conf).
# Bu dosya (.env) gitignored → gerçek sırlar güvende. [[project_profiles]]
# ============================================================================

# ── Binance API (LIVE profiller için gerekli; PAPER'da boş bırak) ────────────
# Live profil seçtiysen (live-general/xs/carry/blend) bu ikisini doldur.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Telegram (opsiyonel: salt-okuma sorgu botu /status /pos /pnl + kritik alarm) ─
# İstemiyorsan boş bırak; bot/alarm sessizce devre dışı kalır.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Veri (paylaşılan; normalde değiştirme — profiller DB_PATH'i _base'den alır) ──
# DB_PATH        = data/trader.db              (paylaşılan mum/funding; profile-base'de)
# STATE_DB_PATH  = data/profiles/<profil>.db   (profil-bazlı equity+pozisyon; use ile)
# Bu ikisi profiller tarafından yönetilir; .env'de override ETME (karışıklık olur).
